@page
@model TripSync___Travel_Planner.Pages.EditExpenseModel

<section class="page-shell narrow">
    <div class="section-heading">
        <p class="eyebrow">Trip cost</p>
        <h1>Edit Expense</h1>
        <p>Update the amount, category, or note for this shared trip cost.</p>
    </div>

    <form method="post" class="app-card form-card">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <input asp-for="ExpenseId" type="hidden" />
        <input asp-for="TripId" type="hidden" />

        <label asp-for="Amount" class="form-label"></label>
        <input asp-for="Amount" class="form-control" type="number" step="0.01" required />
        <span asp-validation-for="Amount" class="text-danger"></span>

        <label asp-for="Category" class="form-label"></label>
        <input asp-for="Category" class="form-control" type="text" />
        <span asp-validation-for="Category" class="text-danger"></span>

        <label asp-for="Description" class="form-label"></label>
        <input asp-for="Description" class="form-control" type="text" />
        <span asp-validation-for="Description" class="text-danger"></span>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Expense</button>
            <a asp-page="/Expenses" asp-route-tripId="@Model.TripId" class="btn btn-ghost">Cancel</a>
        </div>
    </form>
</section>

<partial name="_ValidationScriptsPartial" />
